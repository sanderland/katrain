#:kivy 2.3.0
#:import i18n katrain.core.lang.i18n

#:import PLAYER_TYPES katrain.core.constants.PLAYER_TYPES
#:import PLAYER_HUMAN katrain.core.constants.PLAYER_HUMAN
#:import PLAYER_AI    katrain.core.constants.PLAYER_AI
#:import PLAYING_NORMAL katrain.core.constants.PLAYING_NORMAL
#:import PLAYING_TEACHING katrain.core.constants.PLAYING_TEACHING
#:import MODE_PLAY katrain.core.constants.MODE_PLAY
#:import MODE_ANALYZE katrain.core.constants.MODE_ANALYZE
#:import STATUS_INFO katrain.core.constants.STATUS_INFO

#:import Theme katrain.gui.theme.Theme
#:import BLACK katrain.gui.theme.BLACK
#:import LIGHTER_GREY katrain.gui.theme.LIGHTER_GREY


#:set EPSILON 1e-9

# for sizing help
#<Label>:
#    canvas.before:
#        Color:
#            rgba: [1,0,0,1]
#        Line:
#            rectangle:  (*self.pos,*self.size)
#            width: 1



# mixins
<BackgroundMixin>:
    canvas.before:
        Color:
            rgba: root.background_color
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [root.background_radius, ]
        Color:
            rgba: root.outline_color
        Line:
            rounded_rectangle: (self.x + root.outline_width, self.y + root.outline_width, self.width - 2 * root.outline_width, self.height - 2*root.outline_width, root.background_radius,root.background_radius,root.background_radius,root.background_radius,max(1,root.height))
            width: root.outline_width or 1

# style checkboxes for light theme
<CheckBox>:
    color: 0, 0, 0, 0
    canvas.after:
        Color:
            rgba: (0.78, 0.78, 0.80, 0.6) if self.disabled else (Theme.CHECKBOX_COLOR if self.active else (0.72, 0.72, 0.75, 1))
        RoundedRectangle:
            pos: self.x + dp(2), self.y + dp(2)
            size: self.width - dp(4), self.height - dp(4)
            radius: [dp(4)]
        Color:
            rgba: [1, 1, 1, 1] if self.active and not self.disabled else [0, 0, 0, 0]
        RoundedRectangle:
            pos: self.x + dp(3), self.y + dp(3)
            size: self.width - dp(6), self.height - dp(6)
            radius: [dp(3)]
        Color:
            rgba: (0, 0, 0, 0) if (self.disabled or (not self.active)) else Theme.CHECKBOX_COLOR
        Line:
            points: [self.x + self.width * 0.24, self.y + self.height * 0.52, self.x + self.width * 0.42, self.y + self.height * 0.32, self.x + self.width * 0.76, self.y + self.height * 0.72]
            width: dp(1.8)
            cap: 'round'
            joint: 'round'

# table cells, stats panel mainly

<TableCellLabel>:
    font_size: self.height/3
    padding: [6, 6]
    line_height: 0.8
    halign: 'center'
    canvas.before:
        Color:
            rgba: root.background_color
        Rectangle:
            size: self.size
            pos: self.pos
    canvas:
        Color:
            rgba: root.outline_color
        Line: # left
            points: (root.x + root.outline_width,root.y,root.x + root.outline_width,root.y+root.size[1])
            width: root.outline_width if 'left' in root.outlines else 1e-6
            cap: 'square'
        Line: # right
            points: (root.x + root.size[0] - root.outline_width,root.y,root.x + root.size[0] - root.outline_width,root.y+root.size[1])
            width: root.outline_width if 'right' in root.outlines else 1e-6
            cap: 'square'
        Line: # top
            points: (root.x, root.y+root.size[1]-root.outline_width, root.x + root.size[0], root.y+root.size[1]-root.outline_width)
            width: root.outline_width if 'top' in root.outlines else 1e-6
            cap: 'square'
        Line: # bottom
            points:  (root.x, root.y+root.outline_width, root.x + root.size[0], root.y+root.outline_width)
            width: root.outline_width * int('bottom' in root.outlines) + 1e-6
            cap: 'square'

<TableHeaderLabel>:
    font_size: self.height/2.5

<TableStatLabel>:
    canvas.before:
        Color:
            rgba: root.bar_color
        Rectangle:
            pos: root.x if root.side=='right' else root.x+root.size[0]*(1 - min(1,root.value/root.scale)), root.y
            size: root.size[0] * min(1,root.value/root.scale), root.size[1]


# new widgets


<SizedButton>:
    text_color: Theme.TEXT_COLOR
    background_color: Theme.BOX_BACKGROUND_COLOR
    background_radius: dp(Theme.RADIUS_SM)
    label: label
    Label:
        id: label
        padding: [root.padding_x,root.padding_y]
        color: root.text_color
        font_name: root.font_name
        font_size: 0.6 * self.height / len(self.text.split('\\n')) if root._font_size is None else root._font_size
        halign: root.halign
        valign: 'middle'
        text: root.text

<AutoSizedButton>:
    size_hint_x: None
    width: root.label.texture_size[0] + 2 * self.padding_x if root.label else 100

<ToggleButtonMixin>:
    inactive_background_color: Theme.LIGHTER_BACKGROUND_COLOR
    active_background_color: Theme.BOX_BACKGROUND_COLOR
    background_color: self.active_background_color if self.state=='down' else self.inactive_background_color
    outline_color: self.active_outline_color if self.state=='down' else self.inactive_outline_color

<SizedRectangleButton>:
    outline_color: Theme.BORDER_COLOR
    text_color: Theme.TEXT_COLOR
    background_radius: dp(Theme.RADIUS_SM)

<AutoSizedRectangleButton>:
    outline_color: Theme.BORDER_COLOR
    text_color: Theme.TEXT_COLOR
    background_radius: dp(Theme.RADIUS_SM)

<SizedRectangleToggleButton>:
    inactive_outline_color: [0,0,0,0]
    active_outline_color: Theme.PLAY_ANALYZE_TAB_COLOR
    text_color: Theme.TEXT_COLOR if self.state=='down' else Theme.TEXT_SECONDARY_COLOR
    background_radius: dp(Theme.RADIUS_SM)

<AutoSizedRectangleToggleButton>:
    inactive_outline_color: [0,0,0,0]
    active_outline_color: Theme.PLAY_ANALYZE_TAB_COLOR
    text_color: Theme.TEXT_COLOR if self.state=='down' else Theme.TEXT_SECONDARY_COLOR
    background_radius: dp(Theme.RADIUS_SM)

<SizedRoundedRectangleButton@SizedRectangleButton>:
    background_radius: dp(Theme.RADIUS_MD)

<AutoSizedRoundedRectangleButton@AutoSizedRectangleButton>:
    background_radius: dp(Theme.RADIUS_MD)

<BGBoxLayout>:
    background_color: Theme.BACKGROUND_COLOR

<TransparentIconButton>:
    background_normal: ''
    background_color: (0,0,0,0)
    image: image
    Image:
        id: image
        size: root.icon_size
        pos: [root.pos[i] + (root.size[i] - root.icon_size[i])/2 for i in [0,1]]
        source: root.icon
        mipmap: True
        color: [0,0,0,0.25] if root.disabled else root.color


<I18NSpinnerOption@SpinnerOption>:
    background_color: Theme.BOX_BACKGROUND_COLOR
    background_normal: ''
    lang_change_tracking: i18n._('') # for font
    color: Theme.INPUT_FONT_COLOR
    canvas.after:
        Color:
            rgba: Theme.BORDER_COLOR
        Line
            points: self.x,self.y,self.x+self.width,self.y
            width: 1

<Spinner>:
    -font_size: max(sp(13), self.height * 0.45)
    background_normal: ''
    background_down: ''
    background_color: Theme.LIGHTER_BACKGROUND_COLOR
    color: Theme.TEXT_COLOR
    option_cls: 'I18NSpinnerOption'
    canvas.after:
        Color:
            rgba: Theme.BORDER_COLOR
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(Theme.RADIUS_SM)
            width: 1

<Button>:
    track_lang: i18n._('')

<I18NSpinner>
    sync_height_frac: 1.0

<CircleWithText>:
    min_size: min(self.height,self.width)
    Image:
        id: image
        pos: (root.pos[0] + (root.width - root.min_size)/2,root.pos[1] + (root.height - root.min_size)/2)
        size: (root.min_size,root.min_size)
        source: 'white_circle.png' if root.player=='W' else 'black_circle.png'
        mipmap: True
    Label:
        id: lbl
        text: root.text
        text_size: None, root.min_size
        bold: True
        valign: 'center'
        color: Theme.CIRCLE_TEXT_COLORS[root.player]
        pos: (image.x, image.y)
        size: image.size
        font_size: root.min_size * 1.2 / (1 + 1 * len(self.text))

# UI components

<BadukPanWidget>:
    size: (self.parent.height if self.parent else 0), (self.parent.height if self.parent else 0)
    katrain: app.gui

<ScoreGraph>:
    katrain: app.gui


<NavIconButton@TransparentIconButton>:
    size_hint: 0.055, 0.5
    icon_size: [min(self.size[0],self.height)*0.85, min(self.size[0],self.height)*0.85]
    pos_hint: {'center_y': 0.5}
    color: Theme.TEXT_COLOR

<BadukPanControls>:
    katrain: app.gui
    circles: [black_circle,white_circle]
    mid_circles_container: mid_circles_container
    pass_btn: pass_btn
    canvas.before:
        Color:
            rgba: Theme.BACKGROUND_COLOR
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: Theme.BORDER_COLOR
        Line:
            points: self.x, self.y + self.height, self.x + self.width, self.y + self.height
            width: 1
    AutoSizedRoundedRectangleButton:
        id: pass_btn
        text: i18n._('pass-button-text')
        size_hint: None, 0.55
        pos_hint: {'center_x': 0.08,'center_y':0.5}
        background_color: Theme.BOX_BACKGROUND_COLOR
        outline_color: Theme.BORDER_COLOR
        text_color: Theme.TEXT_COLOR
        on_left_release: root.katrain("play",None)
    BoxLayout:
        size_hint: None, 1
        width: 9 * self.height
        pos_hint: {'center_x': 0.48,'center_y':0.5}
        NavIconButton:
            icon: 'Previous-Mistake.png'
            color: Theme.ERROR_COLOR
            on_press: root.katrain('find-mistake','undo')
        NavIconButton:
            icon: 'Previous-End.png'
            on_press: root.katrain('undo',9999)
        NavIconButton:
            icon: 'Previous-5.png'
            on_press: root.katrain('undo',10)
        NavIconButton:
            icon: 'Previous.png'
            on_press: root.katrain('undo')
        FloatLayout:
            size_hint: 0.06, 1
            id: mid_circles_container
            CircleWithText:
                size_hint: 5/8, 0.85
                pos_hint: {'center_x': 0.5-3/16, 'center_y': 0.5}
                id: black_circle
                player: 'B'
                text: ''
            CircleWithText:
                size_hint: 5/8, 0.85
                pos_hint: {'center_x': 0.5+3/16, 'center_y': 0.5}
                id: white_circle
                player: 'W'
                text: ''
        NavIconButton:
            icon: 'Next.png'
            on_press: root.katrain('redo')
        NavIconButton:
            icon: 'Next-5.png'
            on_press: root.katrain('redo',10)
        NavIconButton:
            icon: 'Next-End.png'
            on_press: root.katrain('redo',9999)
        NavIconButton:
            icon: 'Next-Mistake.png'
            color: Theme.ERROR_COLOR
            on_press: root.katrain('find-mistake','redo')
    ClickableLabel:
        pos_hint: {'center_x': 0.92,'center_y':0.5}
        size_hint: None, 0.6
        width: self.height
        canvas.before:
            Color:
                rgba: root.engine_status_col
            Ellipse:
                pos: self.pos[0] + self.width/2 - self.width/5, self.pos[1]  + self.height/2  - self.width/5
                size: self.width*0.4, self.width*0.4
        text: str(root.queries_remaining) if root.queries_remaining >= 3 else ''
        color: [1, 1, 1, 1]
        font_size: max(sp(11), 0.5 * self.width / max(2,len(self.text)))
        on_press: app.gui.controls.set_status(i18n._('ai-ponder'),STATUS_INFO)


<HamburgerButton@TransparentIconButton>:
    icon: 'hamburger.png'
    width: dp(40)
    icon_size: [dp(20), dp(20)]
    color: Theme.TEXT_COLOR

# ---------- components of right pane -------

<PlayerInfo>:
    captures: 0
    player: 'B'
    player_type: 'player:human'
    player_subtype: 'game:normal'
    background_color: Theme.BOX_BACKGROUND_COLOR if self.active else Theme.BACKGROUND_COLOR
    outline_color: [0,0,0,0]
    outline_width: 0
    background_radius: dp(Theme.RADIUS_SM)
    padding: [dp(Theme.SPACING_SM), dp(Theme.SPACING_XS)]
    subtype_label: subtype_label
    canvas.after:
        Color:
            rgba: Theme.PLAY_ANALYZE_TAB_COLOR if self.active else [0,0,0,0]
        Rectangle:
            pos: self.x, self.y
            size: dp(3), self.height
    CircleWithText:
        size_hint_x: 0.22 if root.alignment=='right' else EPSILON
        opacity: 1 if root.alignment=='right' else 0
        player: root.player
        text: str(root.captures)
    BoxLayout:
        size_hint: 1,1
        orientation: 'vertical'
        Label:
            size_hint: 1, 0.55
            text: i18n._(root.player_type)
            font_size: sp(Theme.FONT_SIZE_LG)
            color: Theme.TEXT_COLOR
            max_lines: 1
            halign: 'center'
            valign: 'middle'
        Label:
            id: subtype_label
            text: i18n._(root.player_subtype)
            size_hint: 1, 0.45
            font_size: sp(Theme.FONT_SIZE_SM)
            color: Theme.TEXT_SECONDARY_COLOR
            text_size: self.size
            halign: 'center'
            valign: 'middle'
            shorten: True
            max_lines: 1
    CircleWithText:
        size_hint_x: EPSILON if root.alignment=='right' else 0.22
        opacity: 0 if root.alignment=='right' else 1
        player: root.player
        text: str(root.captures)

<GraphMarkerLabel@Label>:
    valign: 'bottom'
    halign: 'left'
    text: '+0'
    size: self.texture_size


<StatsLabel>:
    orientation: 'horizontal'
    size_hint_y: EPSILON if root.hidden else 1
    opacity: 0 if root.hidden else 1
    Label:
        size_hint: 0.55, 1
        id: desc
        font_size: sp(Theme.FONT_SIZE_SM)
        font_name: root.font_name
        color: Theme.TEXT_SECONDARY_COLOR
        text_size: self.size
        valign: 'middle'
        halign: 'right'
        text: root.label
        max_lines: 1
    Label:
        size_hint: 0.45, 1
        color: root.color
        font_size: sp(Theme.FONT_SIZE_SM)
        font_name: root.font_name
        text_size: self.size
        valign: 'middle'
        halign: 'center'
        bold: True
        text: root.text
        max_lines: 1

<StatsBox>
    orientation: 'vertical'
    background_color: Theme.BOX_BACKGROUND_COLOR
    background_radius: dp(Theme.RADIUS_SM)
    labels: {'score':score_label,'winrate':winrate_label,'points':pointloss_label}
    StatsLabel:
        id: winrate_label
        label: i18n._('stats:winrate')
        text: root.winrate
        color: Theme.WINRATE_COLOR
    StatsLabel:
        id: score_label
        label: i18n._('stats:score')
        text: root.score
        color: Theme.SCORE_COLOR
    StatsLabel:
        id: pointloss_label
        label: i18n._('stats:pointslost') if root.points_lost is None or root.points_lost > 0 else i18n._('stats:pointsgained')
        text: '{}: {:.1f}'.format(i18n._(f'short color {root.player}'), abs(root.points_lost)) if root.points_lost is not None else '...'
        color: Theme.POINTLOSS_COLOR

<ScrollableLabel>:
    background_color: Theme.BOX_BACKGROUND_COLOR
    do_scroll_x: False
    scroll_type: ['bars']
    bar_width: 4
    bar_color: Theme.SCROLLBAR_COLOR
    label: label
    Label:
        id: label
        lang_change_tracking: i18n._('')
        markup: root.markup
        padding: dp(Theme.SPACING_SM), dp(Theme.SPACING_XS)
        font_size: sp(Theme.NOTES_FONT_SIZE)
        line_height: root.line_height
        color: Theme.TEXT_COLOR
        size_hint_y: None
        height: self.texture_size[1]
        text_size: self.width, None
        text: root.text
        on_ref_press: root.dispatch('on_ref_press',args[1])


#:set player_box_height 0.15
#:set timer_box_height  0.3
#:set graph_box_height  0.37
#:set STATS_BOX_HEIGHT  0.27
#:set INFO_BOX_HEIGHT   1


<CollapsablePanelHeader>:
    canvas.after:
        Color:
            rgba: Theme.BORDER_COLOR
        Line:
            width: 1
            points: (self.x,self.y+1,self.x+self.width,self.y+1)


<ControlsPanel>:
    katrain: app.gui
    orientation: 'vertical'
    players: {'B':B_player,'W':W_player}
    graph: graph
    stats: stats
    notes_panel: notes_panel
    info: info
    note: note
    status: status
    move_tree: move_tree
    padding: dp(Theme.SPACING_SM), dp(Theme.SPACING_SM), dp(Theme.SPACING_SM), 0
    spacing: dp(Theme.SPACING_XS)
    canvas.before:
        Color:
            rgba: Theme.BACKGROUND_COLOR
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: [0, 0, 0, 0.06]
        Line:
            points: self.x, self.y, self.x, self.y + self.height
            width: 1
    tab_option_height: max(15,root.height / 32)
    available_height: root.height - (3 * self.tab_option_height + 2*dp(Theme.SPACING_SM) - 4*dp(Theme.SPACING_XS))
    player_box_height: max(48, 0.07 * root.available_height)
    timer_box_height:  max(48, 0.10 * root.available_height)
    graph_height:  max(65, 0.15 * root.height)
    stat_height: max(18, 0.030 * root.height)
    BoxLayout: # -- Players
        size_hint_y: None
        height: root.player_box_height
        spacing: dp(Theme.SPACING_XS)
        PlayerInfo:
            id: B_player
            player: 'B'
        PlayerInfo:
            id: W_player
            player: 'W'
    BoxLayout:
        size_hint_y: None
        height: root.timer_box_height
        MoveTree:
            id: move_tree
            min_height: root.timer_box_height
    CollapsablePanel:
        id: graph_panel
        content_height: graph.height
        options_height: root.tab_option_height
        closed_label: 'closedlabel:scoregraph'
        options: ['score','winrate','points']
        option_colors: [Theme.SCORE_COLOR,Theme.WINRATE_COLOR,Theme.POINTLOSS_COLOR]
        option_active: [True,False,False]
        on_option_state:
            graph.show_graphs(args[1])
            graph.hidden = not (args[1]['score'] or args[1]['winrate'] or args[1]['points'])
        ScoreGraph:
            id: graph
            opacity: 0 if self.hidden else 1
            size_hint_y: None
            height: root.graph_height
    CollapsablePanel:
        id: stats_panel
        num_active: 3
        content_height: self.num_active * root.stat_height + EPSILON
        options_height: root.tab_option_height
        closed_label: 'closedlabel:movestats'
        options: ['score','winrate','points']
        option_colors: [Theme.SCORE_COLOR,Theme.WINRATE_COLOR,Theme.POINTLOSS_COLOR]
        option_active: [True,True,True]
        on_option_state:
            for k, v in args[1].items(): stats.labels[k].hidden = not v
            self.num_active = sum(args[1].values(),0)
        StatsBox:
            id: stats
    CollapsablePanel:
        id: notes_panel
        size_hint_y_open: 1
        closed_label: 'closedlabel:info&notes'
        options: ['info','info-details','notes']
        option_colors: [Theme.INFO_TAB_FONT_COLOR,Theme.INFO_TAB_FONT_COLOR,Theme.NOTES_TAB_FONT_COLOR]
        option_active: [True,False,False]
        on_option_state:
            info.detailed = args[1]['info-details']
            info.size_hint_y = int(args[1]['info'] or info.detailed)+EPSILON
            info.opacity =  int(args[1]['info'] or info.detailed)
            notebox.size_hint_y = int(args[1]['notes'])*0.66+EPSILON
            notebox.opacity = int(args[1]['notes'])
            app.gui.update_state()
        options_height: root.tab_option_height
        BGBoxLayout:
            background_color: Theme.BOX_BACKGROUND_COLOR
            orientation: 'vertical'
            ScrollableLabel:
                id: status
                error: False
                size_hint: 1, None
                height: min(self.parent.height*0.66,self.label.texture_size[1])
                outline_color: Theme.ERROR_BORDER_COLOR if self.error else [0,0,0,0]
                background_color: Theme.LIGHTER_BACKGROUND_COLOR
            ScrollableLabel:
                id: info
                detailed: False
                line_height: 1.25
                markup: True
                on_ref_press: root.katrain.board_gui.show_pv_from_comments(args[1])
                size_hint: 1, 1
                height: self.parent.height - status.height - note.height - 1
            AnchorLayout:
                padding: 0
                id: notebox
                size_hint: 1,0
                LabelledTextInput:
                    id: note
                    font_size: sp(Theme.NOTES_FONT_SIZE)
                    multiline: True
                    on_text: root.katrain.set_note(self.text)
                    hint_text: i18n._('SGF Notes Hint')
                    size_hint: 1, 1
                    canvas.before:
                        Color:
                            rgba: Theme.BORDER_COLOR
                        Line:
                            points: self.x, self.y+self.height, self.x+self.width, self.y+self.height
                            width: 1
    Label:
        size_hint_y: EPSILON # takes up remaining space if info is closed


<MenuItem>
    font_size: sp(Theme.FONT_SIZE_MD)
    size_hint_y: None
    height: dp(48)
    background_color: Theme.BOX_BACKGROUND_COLOR
    background_radius: dp(Theme.RADIUS_SM)
    width_margin: 1.33
    content_width: icon.width + label.texture_size[0] * self.width_margin
    FloatLayout:
        id: icon
        size_hint: None, 1
        width: self.height + 16
        Image:
            id:image
            source: root.icon
            color: Theme.TEXT_SECONDARY_COLOR
            mipmap: True
            size_hint: 0.7,0.7
            pos_hint: {'center_y': 0.5,'center_x': 0.5}
    AnchorLayout:
        size_hint_x: 1
        anchor_x: 'left'
        Label:
            id: label
            text: root.text
            size: self.texture_size
            size_hint: None, None
            font_size: root.font_size
            font_name: root.font_name
            color: Theme.MENU_ITEM_FONT_COLOR
    Label:
        text: root.shortcut
        halign: 'left'
        valign: 'middle'
        size_hint_x: 1/3
        font_size: root.font_size
        font_name: root.font_name
        color: Theme.MENU_ITEM_SHORTCUT_COLOR



<AnalysisToggle>:
    size_hint_x: None
    width: self.minimum_width
    spacing: 2
    size_hint_y: 0.8
    pos_hint: {'center_y':0.5}
    checkbox: checkbox
    label: label
    ClickableLabel:
        id: label
        text: root.text
        halign: 'center'
        font_size: sp(Theme.FONT_SIZE_SM)
        font_name: root.font_name
        color: [0.72, 0.72, 0.75, 1] if root.disabled else (Theme.PLAY_ANALYZE_TAB_COLOR if checkbox.active else Theme.TEXT_SECONDARY_COLOR)
        size_hint_x: None
        width: self.texture_size[0] + dp(8)
        on_left_press: checkbox.trigger_action()
    CheckBox:
        id: checkbox
        disabled: root.disabled
        size_hint: None, 0.45
        pos_hint: {'center_y': 0.5}
        width: self.height
        active: root.default_active
        on_active: if app.gui: app.gui.update_state()


<AnalysisMenuItem@MenuItem>:
    on_close: app.gui.analysis_controls.close_dropdown()
    background_color: Theme.BOX_BACKGROUND_COLOR
    height: dp(42)
    canvas.before:
        Color:
            rgba: Theme.BORDER_COLOR
        Line
            points: self.x,self.y,self.x+self.width,self.y
            width: 1


<AnalysisDropDown>:
    width: 50
    katrain: app.gui
    AnalysisMenuItem:
        text: i18n._("analysis:reset")
        icon: 'reset.png'
        shortcut: 'h'
        on_action: root.katrain("reset-analysis",)
    AnalysisMenuItem:
        text: i18n._("analysis:continuous")
        icon: 'play.png'
        shortcut: 'space'
        on_action: root.katrain.toggle_continuous_analysis()
    AnalysisMenuItem:
        text: i18n._("analysis:aimove")
        icon: 'ai.png'
        shortcut: 'enter'
        on_action: root.katrain("ai-move")


<AnalysisControls>:
    katrain: app.gui
    orientation: 'horizontal'
    spacing: dp(Theme.SPACING_SM)
    padding: [dp(Theme.SPACING_SM), 0]
    show_children: show_children
    eval: eval
    policy: policy
    hints: hints
    ownership: ownership
    analysis_button: analysis_button
    hamburger: hamburger
    canvas.before:
        Color:
            rgba: Theme.BOX_BACKGROUND_COLOR
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: Theme.BORDER_COLOR
        Line:
            points: self.x, self.y, self.x + self.width, self.y
            width: 1
    HamburgerButton:
        id: hamburger
        size_hint: None, 1
        width: dp(40)
        on_press: app.gui.nav_drawer.set_state("open")
    BoxLayout:
        size_hint_x: None
        width: self.minimum_width
        spacing: dp(Theme.SPACING_LG)
        AnalysisToggle:
            id: show_children
            text: i18n._("analysis:nextmoves")
            default_active: True
        AnalysisToggle:
            id: eval
            text: i18n._("analysis:dots")
            tri_state: True
        AnalysisToggle:
            id: hints
            text: i18n._("analysis:topmoves")
            disabled: policy.checkbox.active
        AnalysisToggle:
            id: policy
            text: i18n._("analysis:policy")
        AnalysisToggle:
            id: ownership
            text: i18n._('analysis:territory')
    Widget:
    FloatLayout:
        width: analysis_button.width
        size_hint: None, 1
        AutoSizedRectangleButton:
            background_color: Theme.BOX_BACKGROUND_COLOR
            size_hint_y: 0.6
            pos_hint: {'center_y': 0.5, 'x': 0}
            id: analysis_button
            on_release: root.toggle_dropdown()
            text: '  ' + i18n._("btn:Analyze")
            text_color: Theme.TEXT_COLOR
            background_radius: dp(Theme.RADIUS_SM)
            outline_color: Theme.BORDER_COLOR
        Image:
            pos_hint: {'center_y': 0.5}
            x: self.parent.x + dp(4)
            size_hint: None, 0.35
            width: self.height/2
            source: 'menu.png'
            color: Theme.TEXT_COLOR
            mipmap: True



<MainMenuItem@MenuItem>
    on_close: app.gui.nav_drawer.set_state("close")
    height: dp(44)


<MenuLabel@BackgroundMixin+Label>:
    background_color: Theme.BOX_BACKGROUND_COLOR
    font_size: sp(Theme.FONT_SIZE_SM)
    color: Theme.TEXT_SECONDARY_COLOR
    height: dp(44)
    size_hint: 1,None

<MenuLink@ButtonBehavior+MenuLabel>:
    site_key: ''
    underline: True
    on_press: app.webbrowser(self.site_key)

<PlayerSetup>:
    orientation: 'horizontal'
    spacing: dp(Theme.SPACING_SM)
    padding: 0, dp(Theme.SPACING_SM)
    player_type: player_type
    player_subtype_human: player_subtype_human
    player_subtype_ai: player_subtype_ai
    BoxLayout:
        size_hint: 0.2, 1
        ClickableCircle:
            size_hint: 0.8, 0.8
            pos_hint: {'center_x':0.5,'center_y':0.5}
            text: root.player[0]
            player: root.player
            on_left_press: root.parent.swap_players()
    BoxLayout:
        size_hint: 0.5, 1
        orientation: 'vertical'
        spacing: dp(Theme.SPACING_XS)
        Label:
            text: i18n._('player:type')
            font_size: sp(Theme.FONT_SIZE_SM)
            color: Theme.TEXT_SECONDARY_COLOR
        I18NSpinner:
            id: player_type
            value_refs: PLAYER_TYPES
            on_select: root.setup_options(*args)
    BoxLayout:
        size_hint: 0.5, 1
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(Theme.SPACING_XS)
            size_hint_x: 1 if root.mode != PLAYER_AI else EPSILON
            opacity:1 if root.mode != PLAYER_AI else 0
            Label:
                text:  i18n._("gametype")
                font_size: sp(Theme.FONT_SIZE_SM)
                color: Theme.TEXT_SECONDARY_COLOR
            BoxLayout:
                I18NSpinner:
                    id: player_subtype_human
                    value_refs: []
                    on_select: if root.mode==PLAYER_HUMAN: root.update_global_player_info()
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(Theme.SPACING_XS)
            size_hint_x: 1 if root.mode == PLAYER_AI else EPSILON
            opacity: 1 if root.mode == PLAYER_AI else 0
            Label:
                text: i18n._("aistrategy")
                font_size: sp(Theme.FONT_SIZE_SM)
                color: Theme.TEXT_SECONDARY_COLOR
            BoxLayout:
                I18NSpinner:
                    id: player_subtype_ai
                    value_refs: []
                    on_select: if root.mode==PLAYER_AI: root.update_global_player_info()



<PlayerSetupBlock>:
    orientation: 'vertical'
    size_hint_y: None
    spacing: dp(Theme.SPACING_SM)
    padding: dp(Theme.SPACING_SM)
    height: ((getattr(self.parent, "item_height", 50) if self.parent else 50) or 50) * 5




<HamburgerMenuContents@BoxLayout+BackgroundMixin>:
    katrain: app.gui
    background_color: Theme.BOX_BACKGROUND_COLOR
    orientation: 'vertical'
    padding: dp(Theme.SPACING_MD)
    spacing: 0
    canvas.before:
        Color:
            rgba: [0, 0, 0, 0.30 * max(0, self.right) / max(1, self.width)]
        Rectangle:
            pos: self.right, 0
            size: 5000, 5000
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(2)
            # -- Game section --
            MenuLabel:
                text: 'Game'
                font_size: sp(Theme.FONT_SIZE_SM)
                color: Theme.TEXT_TERTIARY_COLOR
                height: dp(28)
                halign: 'left'
                padding: [dp(Theme.SPACING_SM), 0]
                text_size: self.size
                valign: 'middle'
            MainMenuItem:
                text: i18n._('menu:newgame')
                icon: 'New-Game.png'
                shortcut: 'Ctrl-N'
                on_action: root.katrain("new-game-popup")
            MainMenuItem:
                text: i18n._('menu:load')
                icon: 'Load-Game.png'
                shortcut: 'Ctrl-L'
                on_action: root.katrain("analyze-sgf-popup")
            MainMenuItem:
                text: i18n._('menu:save')
                icon: 'Save-Game.png'
                shortcut: 'Ctrl-S'
                on_action: root.katrain("save-game")
            MainMenuItem:
                text: i18n._('menu:save-as')
                icon: 'Save-Game-As.png'
                shortcut: 'Ctrl-D'
                on_action: root.katrain("save-game-as-popup")
            # -- Settings section --
            MenuLabel:
                text: 'Settings'
                font_size: sp(Theme.FONT_SIZE_SM)
                color: Theme.TEXT_TERTIARY_COLOR
                height: dp(32)
                halign: 'left'
                padding: [dp(Theme.SPACING_SM), 0]
                text_size: self.size
                valign: 'bottom'
            MainMenuItem:
                text: i18n._('menu:aisettings')
                icon: 'AI-Settings.png'
                shortcut: 'F7'
                on_action: root.katrain('ai-popup')
            MainMenuItem:
                text: i18n._('menu:settings')
                icon: 'General-Settings.png'
                shortcut: 'F8'
                on_action: root.katrain('config-popup')
            # -- Help section --
            MenuLabel:
                text: 'Help'
                font_size: sp(Theme.FONT_SIZE_SM)
                color: Theme.TEXT_TERTIARY_COLOR
                height: dp(32)
                halign: 'left'
                padding: [dp(Theme.SPACING_SM), 0]
                text_size: self.size
                valign: 'bottom'
            MainMenuItem:
                text: i18n._('menu:manual')
                icon: 'analysis.png'
                on_action: app.webbrowser('homepage')


<OutlineBox@BoxLayout+BackgroundMixin>:


<PlayAnalyzeButton@SizedToggleButton>:
    inactive_background_color: [0, 0, 0, 0]
    active_background_color: Theme.PLAY_ANALYZE_TAB_COLOR
    text_color: [1, 1, 1, 1] if self.state=='down' else Theme.TEXT_SECONDARY_COLOR
    size_hint: 0.5, 1
    _font_size: sp(Theme.FONT_SIZE_MD)
    group: 'play_analyze'
    allow_no_selection: False
    background_radius: 0

<PlayAnalyzeSelect>:
    katrain: app.gui
    play: play
    analyze: analyze
    canvas.before:
        Color:
            rgba: Theme.LIGHTER_BACKGROUND_COLOR
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: Theme.BORDER_COLOR
        Line:
            points: self.x, self.y, self.x + self.width, self.y
            width: 1
    OutlineBox:
        size_hint: 1, 1
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        background_radius: 0
        background_color: Theme.LIGHTER_BACKGROUND_COLOR
        outline_color: [0,0,0,0]
        PlayAnalyzeButton:
            text: i18n._('btn:Play')
            id: play
            state: 'down'
            on_state: if self.state=='down': root.select_mode(MODE_PLAY)
        PlayAnalyzeButton:
            text: i18n._('btn:Analysis')
            id: analyze
            on_state: if self.state=='down': root.select_mode(MODE_ANALYZE)



## NOTE: `KaTrainGui` is now Python-built (see `katrain/__main__.py`).
