#:kivy 2.3.0
#:import i18n katrain.core.lang.i18n
#:import kivy_version kivy.__version__

#:import Theme katrain.gui.theme.Theme
#:import LIGHT_GREY katrain.gui.theme.LIGHT_GREY

#:set CP_SPACING Theme.CP_SPACING
#:set CP_SMALL_SPACING Theme.CP_SMALL_SPACING
#:set CP_PADDING Theme.CP_PADDING

# ---------------------------------------------------------------------------
# Minimal popup KV.
# This file intentionally contains only lightweight style rules and the
# remaining popup layouts that are still KV-defined.
# ---------------------------------------------------------------------------

<LabelledTextInput>:
    font_size: sp(Theme.INPUT_FONT_SIZE)
    hint_text: ""

<LabelledPathInput>:
    font_size: sp(16)
    multiline: False
    write_tab: False

<LabelledIntInput>:
    font_size: sp(Theme.INPUT_FONT_SIZE)
    write_tab: False
    size_hint: 0.5, None

<LabelledFloatInput>:
    font_size: sp(Theme.INPUT_FONT_SIZE)
    write_tab: False
    size_hint: 0.5, None

<LabelledCheckBox>:
    size: sp(Theme.DESC_FONT_SIZE)*2,sp(Theme.DESC_FONT_SIZE)*2
    size_hint: None,None

<I18NPopup>:
    background_color: Theme.BACKGROUND_COLOR
    background: self.background if kivy_version < '2.0' else ''
    title: i18n._(self.title_key)
    title_size: sp(Theme.DESC_FONT_SIZE)
    title_font: self.font_name
    size_hint: None, None

<DescriptionLabel>:
    font_size: sp(Theme.DESC_FONT_SIZE)
    multiline: True
    text_size: self.width, None
    halign: 'center'
    valign: 'center'

<SmallDescriptionLabel@DescriptionLabel>
    font_size: sp(Theme.DESC_FONT_SIZE) * 0.66

<LabelledSelectionSlider>:
    slider: slider
    textbox: textbox
    SelectionSlider:
        id: slider
        size_hint: 2.25,1
        values: root.values
        on_change: textbox.text = str(slider.value)
        track_color: LIGHT_GREY
        thumb_color: (0.6, 0.7, 0.9, 1) if root.key_option else (0.3, 0.4, 0.6, 1)
    LabelledFloatInput:
        id: textbox

<EngineRecoveryPopup>:
    Label:
        padding: CP_PADDING, CP_PADDING*3
        text: i18n._("engine died popup opening message").format(code=root.code,error_message=root.error_message) + "\\n\\n" +  i18n._("change engine suggestion").format(link="[color=#CCCC11][u][ref=engine_settings]"+i18n._('menu:settings')+"[/ref][/u][/color]") + "\\n\\n" +  i18n._("go to engine help page").format(link="[color=#CCCC11][u][ref=engine_help]"+i18n._('link_here')+"[/ref][/u][/color]")
        text_size: self.size
        font_size: sp(Theme.DESC_FONT_SIZE)
        markup: True
        valign: 'top'
        on_ref_press:  app.webbrowser('engine:help') if args[1]=='engine_help' else  app.gui('config-popup')

<ReAnalyzeGamePopup>:
    visits: visits
    orientation: 'vertical'
    button: button
    move_range: move_range
    start_move: start_move
    end_move: end_move
    mistakes: mistakes
    BoxLayout:
        size_hint: 1, 1.5
        orientation: 'vertical'
        GridLayout:
            cols: 2
            rows: 2
            size_hint: 1, 2
            DescriptionLabel:
                text: i18n._('reanalyze max visits')
            AnchorLayout:
                LabelledIntInput:
                    id: visits
                    text: '2500'
            BoxLayout:
                AnchorLayout:
                    size_hint: 0.3333, 1
                    LabelledCheckBox:
                        id: move_range
                        default_active: False
                DescriptionLabel:
                    size_hint: 0.6667, 1
                    text: i18n._('limit to moves')
                    halign: 'left'
            BoxLayout:
                AnchorLayout:
                    LabelledIntInput:
                        helper_text: i18n._('from move')
                        helper_text_mode: "persistent"
                        id: start_move
                        text: '0'
                AnchorLayout:
                    LabelledIntInput:
                        helper_text: i18n._('to move')
                        helper_text_mode: "persistent"
                        id: end_move
                        text: '999'
        BoxLayout:
            size_hint: 1, 1
            AnchorLayout:
                size_hint: 0.16666, 1
                LabelledCheckBox:
                    id: mistakes
                    default_active: False
            DescriptionLabel:
                size_hint: 0.833333, 1
                text: i18n._('reanalyze mistakes only')
                halign: 'left'
        AnchorLayout:
            size_hint: 1, 0.66
            AutoSizedRoundedRectangleButton:
                id: button
                padding_x: 15
                size_hint: None,0.66
                text: i18n._("analysis:game")
                on_press:
                    root.katrain("analyze-extra", "game", visits=visits.input_value, move_range=(start_move.input_value, end_move.input_value) if move_range.input_value else None, mistakes_only=mistakes.input_value)
                    root.popup.dismiss()

<TsumegoFramePopup>:
    ko: ko
    margin: margin
    orientation: 'vertical'
    button: button
    BoxLayout:
        size_hint: 1, 1.5
        orientation: 'horizontal'
        DescriptionLabel:
            text: i18n._('tsumego:walldistance')
        AnchorLayout:
            LabelledIntInput:
                id: margin
                text: '4'
    BoxLayout:
        size_hint: 1, 1.5
        orientation: 'horizontal'
        DescriptionLabel:
            text: i18n._('tsumego:ko')
        AnchorLayout:
            LabelledCheckBox:
                id: ko
    AnchorLayout:
        size_hint: 1, 1
        AutoSizedRoundedRectangleButton:
            id: button
            padding_x: 15
            size_hint: None,0.66
            text: i18n._("analysis:tsumegoframe")
            on_press:
                root.katrain("tsumego-frame", ko=ko.input_value, margin=margin.input_value)
                root.popup.dismiss()

<LoadSGFPopup>:
    fast: fast
    rewind: rewind
    filesel: filesel
    orientation: 'vertical'
    AnchorLayout:
        size_hint: 1,1
        BoxLayout:
            size_hint: 0.5,1
            orientation: 'horizontal'
            DescriptionLabel:
                text: i18n._("load sgf fast analysis")
                size_hint: 0.45,1
                halign: 'right'
            LabelledCheckBox:
                id: fast
                size_hint: 0.05,1
                input_property: "general/load_fast_analysis"
            DescriptionLabel:
                text: i18n._("load sgf rewind")
                halign: 'right'
                size_hint: 0.45,1
            LabelledCheckBox:
                id: rewind
                active: True
                size_hint: 0.05,1
                input_property: "general/load_sgf_rewind"
    I18NFileBrowser:
        id: filesel
        multiselect: False
        file_must_exist: True
        filters: ["*.sgf","*.gib","*.ngf"]
        path: "."
        size_hint: 1,7

<SaveSGFPopup>:
    filesel: filesel
    orientation: 'vertical'
    I18NFileBrowser:
        id: filesel
        multiselect: False
        file_must_exist: False
        filters: ["*.sgf","*.gib","*.ngf"]
        path: "."
        size_hint: 1,7

<GameReportPopup>
    player_infos: {'B': player_b, 'W': player_w}
    stats: stats
    orientation: 'vertical'
    padding: Theme.CP_PADDING
    BoxLayout:
        size_hint_y: 0.8
        spacing: CP_SPACING
        padding: CP_PADDING
        SizedRectangleToggleButton:
            text: i18n._('Entire Game')
            allow_no_selection: False
            size_hint: 1,1
            group: 'stats_depth'
            state: 'down'
            on_press: root.set_depth_filter(None)
        SizedRectangleToggleButton:
            text: i18n._('Opening')
            allow_no_selection: False
            size_hint: 1,1
            group: 'stats_depth'
            on_press: root.set_depth_filter((0,0.14))
        SizedRectangleToggleButton:
            text: i18n._('Midgame')
            allow_no_selection: False
            size_hint: 1,1
            group: 'stats_depth'
            on_press: root.set_depth_filter((0.14,0.4))
        SizedRectangleToggleButton:
            text: i18n._('Endgame')
            group: 'stats_depth'
            allow_no_selection: False
            size_hint: 1,1
            on_press: root.set_depth_filter((0.4,10))
    BoxLayout:
        size_hint_y: 1.33
        PlayerInfo:
            player: 'B'
            id: player_b
        PlayerInfo:
            player: 'W'
            id: player_w
            alignment: 'left'
    BoxLayout:
        id: stats
        size_hint_y: 10

